{
  "name": "cutlass",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -b && vite build --mode lib",
    "check": "biome check --write .",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "main": "./dist/lib/cutlass.js",
  "module": "./dist/lib/cutlass.js",
  "types": "./dist/lib/cutlass.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/cutlass.js",
      "types": "./dist/lib/cutlass.d.ts"
    }
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@tailwindcss/vite": "^4.2.1",
    "immer": "^11.1.4",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "wavesurfer.js": "^7.12.1",
    "zundo": "^2.3.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
